# ==========================================
# BechoHub Remote Engineering Environment setup
# DO NOT ADD REAL PASSWORDS TO THIS FILE!
# Copy this file to '.env' and fill in your local values.
# ==========================================

# Server configuration
PORT=3000

# Authentication Secret (Used locally to sign JWTs)
# To generate a safe one locally: Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET="your_local_jwt_secret_here"

# Database Configuration
# Local PostgreSQL endpoint (Replace with your local DB or staging URI)
# Standard format: "postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DATABASE_URL="postgresql://postgres:password@localhost:5432/bechohub"
