generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  password      String
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  companyName   String?   @map("company_name")
  roles         Role[]    @default([BUYER])
  category      String?
  businessScale String?   @map("business_scale")
  gstNumber     String?   @map("gst_number")
  createdAt     DateTime  @default(now()) @map("created_at")
  buyerOrders   Order[]   @relation("BuyerOrders")
  sellerOrders  Order[]   @relation("SellerOrders")
  sellerProfile Seller?

  @@map("profiles")
}

model Seller {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  businessName String   @map("business_name")
  displayName String?   @map("display_name")
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  status      SellerStatus @default(ACTIVE)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products    Product[]

  @@index([userId])
  @@index([createdAt])
  @@map("sellers")
}

model Product {
  id          String          @id @default(uuid()) @db.Uuid
  sellerId    String          @map("seller_id") @db.Uuid
  productName String          @map("product_name")
  quantity    Int
  price       Decimal         @db.Decimal(12, 2)
  location    String
  description String?
  searchVector Unsupported("tsvector")?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  orders      Order[]
  seller      Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images      ProductImage[]

  @@index([sellerId])
  @@index([productName])
  @@index([location])
  @@index([createdAt])
  @@map("products")
}

model ProductImage {
  id            String   @id @default(uuid()) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  imageUrl      String   @map("image_url")
  storagePath   String?  @map("storage_path")
  thumbnailUrl  String?  @map("thumbnail_url")
  thumbnailPath String?  @map("thumbnail_path")
  mobileUrl     String?  @map("mobile_url")
  mobilePath    String?  @map("mobile_path")
  desktopUrl    String?  @map("desktop_url")
  desktopPath   String?  @map("desktop_path")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  productId     String        @db.Uuid
  quantity      Int           @default(1)
  totalPrice    Float
  buyerId       String        @db.Uuid
  sellerId      String        @db.Uuid
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  buyer         User          @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller        User          @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum SellerStatus {
  ACTIVE
  SUSPENDED
}
